{
  "name": "hexhaven-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.11.0",
  "scripts": {
    "dev": "concurrently \"pnpm --filter @hexhaven/server dev\" \"pnpm --filter @hexhaven/client dev\"",
    "test": "vitest run",
    "typecheck": "tsc -b",
    "lint": "eslint .",
    "build": "pnpm -r build",
    "e2e": "pnpm -w build && playwright test --config e2e/playwright.config.ts lobby",
    "e2e:full": "pnpm -w build && playwright test --config e2e/playwright.config.ts"
  },
  "devDependencies": {
    "@hexhaven/engine": "workspace:*",
    "@hexhaven/shared": "workspace:*",
    "@eslint/js": "9.18.0",
    "@playwright/test": "1.49.1",
    "@types/node": "22.12.0",
    "concurrently": "8.2.2",
    "eslint": "9.18.0",
    "prettier": "3.4.2",
    "typescript": "5.7.3",
    "typescript-eslint": "8.20.0",
    "vitest": "2.1.8"
  }
}
